/* Home 页面特定样式 - 精简版 */

/* 每日推荐食谱 */
.daily-food-card {
  border-left: 6rpx solid var(--primary);
}
.daily-food-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.daily-food-name {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--primary);
}
.daily-food-arrow {
  font-size: 36rpx;
  color: var(--text-muted);
}
.daily-food-reason {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 8rpx;
}
.daily-food-tap-hint {
  font-size: 22rpx;
  color: var(--accent);
  display: block;
  margin-top: 8rpx;
}

/* 打卡提示 */
.checkin-tip {
  font-size: 24rpx;
  color: var(--accent);
  background: rgba(168, 201, 154, 0.08);
  border: 1rpx solid rgba(168, 201, 154, 0.2);
  border-radius: var(--radius-sm);
  padding: 20rpx 28rpx;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

/* 九种体质 */
.chip {
  display: inline-block;
  border: 2rpx solid var(--border);
  border-radius: 30rpx;
  padding: 10rpx 24rpx;
  margin-right: 16rpx;
  font-size: 24rpx;
  background: var(--surface);
  color: var(--text-secondary);
}
.card-sub {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 16rpx;
  display: block;
}

/* 体质详情弹窗 */
.consti-desc {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.6;
  margin-bottom: 16rpx;
}
.consti-section {
  margin-top: 20rpx;
}
.consti-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
  display: block;
  margin-bottom: 8rpx;
}
.consti-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  display: block;
}

/* 食谱详情弹窗 */
.recipe-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
  display: block;
  margin-bottom: 16rpx;
}
.recipe-item-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
.recipe-item {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  display: block;
}
.recipe-step-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.recipe-step {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  display: block;
}