.container{padding:20rpx 30rpx}
.header{margin:20rpx 0 30rpx}
.greeting{font-size:40rpx;font-weight:700}
.subtitle{font-size:26rpx;color:var(--text-secondary);margin-top:8rpx;display:block}
.stats-row{display:flex;gap:16rpx;margin-bottom:24rpx}
.stat-item{flex:1;background:var(--surface);border-radius:var(--radius);padding:18rpx 10rpx;text-align:center}
.stat-num{font-size:30rpx;font-weight:700;color:var(--primary);display:block}
.stat-label{font-size:20rpx;color:var(--text-muted);margin-top:4rpx;display:block}
.card{background:var(--surface);border-radius:var(--radius);padding:28rpx;margin-bottom:20rpx}
.card-title{font-size:28rpx;font-weight:600;display:block;margin-bottom:12rpx}
.daily-food{font-size:44rpx;font-weight:700;color:var(--primary);display:block}
.card-sub{font-size:24rpx;color:var(--text-muted);margin-top:8rpx;display:block}
.streak-text{font-size:24rpx;color:var(--warm)}
.solar-name{font-size:36rpx;font-weight:700;color:var(--accent)}
.grid{display:flex;flex-wrap:wrap;gap:16rpx;margin-bottom:20rpx}
.grid-item{width:calc(50% - 8rpx);background:var(--surface);border-radius:var(--radius);padding:30rpx 20rpx;text-align:center;box-sizing:border-box}
.grid-icon{font-size:48rpx;display:block}
.grid-label{font-size:26rpx;margin-top:8rpx}
.chip-scroll{white-space:nowrap;padding:10rpx 0}
.chip{display:inline-block;border:2rpx solid;border-radius:30rpx;padding:10rpx 24rpx;margin-right:16rpx;font-size:24rpx}
.constitution-info{display:flex;align-items:center;gap:12rpx;margin-bottom:8rpx}
.constitution-emoji{font-size:48rpx}
.constitutionName{font-size:36rpx;font-weight:700;color:var(--primary)}
.constitution-principle{font-size:26rpx;color:var(--text-secondary);display:block}
.disclaimer{text-align:center;font-size:22rpx;color:var(--text-muted);padding:30rpx 20rpx}

.poetry-card{background:linear-gradient(135deg,var(--surface) 0%,#f8f6f3 100%);border-left:6rpx solid var(--accent)}
.poem-content{margin:16rpx 0;padding:20rpx;background:rgba(255,255,255,0.6);border-radius:16rpx}
.poem-text{font-size:28rpx;color:var(--text-primary);line-height:1.8;display:block;font-family:KaiTi,STKaiti,serif}
.poem-author{font-size:24rpx;color:var(--text-muted);margin-top:12rpx;display:block;text-align:right;font-family:KaiTi,STKaiti,serif}
.card-tip{font-size:22rpx;color:var(--accent);font-style:italic}

.poetry-modal{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:1000;display:flex;align-items:center;justify-content:center;padding:40rpx}
.modal-content{width:100%;max-height:85vh;background:#fffef8;border-radius:24rpx;overflow:hidden;display:flex;flex-direction:column}
.modal-header{display:flex;justify-content:space-between;align-items:center;padding:32rpx 36rpx;border-bottom:1rpx solid #e8e4dc}
.modal-title{font-size:36rpx;font-weight:700;color:var(--accent);font-family:KaiTi,STKaiti,serif}
.modal-close{font-size:48rpx;color:#999;line-height:1}
.modal-body{flex:1;overflow-y:auto;padding:32rpx 36rpx}
.modal-poem{padding:24rpx;background:#f9f7f2;border-radius:16rpx;margin-bottom:32rpx}
.modal-poem-text{font-size:30rpx;color:#333;line-height:2;font-family:KaiTi,STKaiti,serif;display:block}
.modal-poem-author{font-size:26rpx;color:#888;margin-top:16rpx;display:block;text-align:right;font-family:KaiTi,STKaiti,serif}
.modal-divider{height:1rpx;background:#e8e4dc;margin:24rpx 0}
.modal-story{}
.story-title{font-size:30rpx;font-weight:600;color:var(--accent);margin-bottom:16rpx;display:block}
.story-content{font-size:28rpx;color:#555;line-height:1.8;display:block}
.modal-tip{}
.tip-title{font-size:30rpx;font-weight:600;color:#5a8a5a;margin-bottom:12rpx;display:block}
.tip-content{font-size:26rpx;color:#666;line-height:1.6;display:block}
.modal-footer{padding:24rpx 36rpx;border-top:1rpx solid #e8e4dc;text-align:center}
.modal-btn{display:inline-block;padding:16rpx 48rpx;background:var(--accent);color:#fff;font-size:28rpx;border-radius:40rpx}