.page {
  padding: 30rpx;
  padding-bottom: 120rpx;
}

.header {
  background: linear-gradient(135deg, var(--surface) 0%, var(--bg-card) 100%);
  border-radius: var(--radius);
  padding: 36rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--border);
}
.hi {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}
.emoji {
  font-size: 72rpx;
}
.hname {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
  display: block;
}
.hprinciple {
  font-size: 24rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 4rpx;
}
.hdesc {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-top: 12rpx;
}

.section {
  background: var(--surface);
  border-radius: var(--radius);
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--border);
}
.stitle {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: var(--text);
}
.srow {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.sname {
  width: 120rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}
.strack {
  flex: 1;
  height: 16rpx;
  background: var(--bg);
  border-radius: 8rpx;
  margin: 0 12rpx;
  overflow: hidden;
}
.sfill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.5s ease;
}
.sval {
  width: 60rpx;
  text-align: right;
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 600;
}

.tbar {
  white-space: nowrap;
  background: var(--surface);
  border-radius: var(--radius);
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  gap: 12rpx;
  border: 1rpx solid var(--border);
}
.tab {
  display: inline-block;
  padding: 14rpx 32rpx;
  font-size: 26rpx;
  border-radius: 30rpx;
  background: var(--bg-card);
  color: var(--text-secondary);
  transition: all 0.2s;
}
.tab.active {
  background: var(--primary);
  color: #fff;
  font-weight: 600;
}

.content {
  background: var(--surface);
  border-radius: var(--radius);
  padding: 28rpx;
  margin-bottom: 24rpx;
  min-height: 300rpx;
  border: 1rpx solid var(--border);
}

.tag {
  display: inline-block;
  padding: 10rpx 22rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  margin: 8rpx;
  background: var(--bg-card);
  color: var(--text-secondary);
}
.tag-g {
  background: var(--primary-glow);
  color: var(--primary);
  border: 1rpx solid var(--primary);
}
.tag-r {
  background: rgba(212, 90, 90, 0.12);
  color: #D45A5A;
  border: 1rpx solid rgba(212, 90, 90, 0.3);
}

.ritem {
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--border);
  font-size: 28rpx;
  color: var(--text);
}
.ritem:last-child {
  border-bottom: none;
}

.blk {
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--border);
}
.blk:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}
.bl {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
  display: block;
  margin-bottom: 10rpx;
}
.bt {
  font-size: 27rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  white-space: pre-wrap;
  display: block;
}

.empty {
  color: var(--text-muted);
  font-size: 28rpx;
  text-align: center;
  padding: 60rpx 0;
}

.actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}
.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  color: #fff;
  background: var(--primary);
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}
.btn-o {
  background: transparent;
  border: 2rpx solid var(--primary);
  color: var(--primary);
}