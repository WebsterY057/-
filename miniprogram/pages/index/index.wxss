.error-tip {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #1A221A;
  color: #aaa;
  font-size: 14px;
  gap: 12px;
  padding: 40px;
}
.error-detail {
  font-size: 12px;
  color: #666;
}
.retry-btn {
  margin-top: 8px;
  padding: 8px 24px;
  background: #4CAF50;
  color: #fff;
  border-radius: 6px;
  font-size: 14px;
  border: none;
}
