page {
  /* Web 同步配色 - 鼠尾草绿暗色主题 */
  --bg: #0E1210;
  --bg-card: #161C18;
  --bg-card-hover: #1E2822;
  --surface: #1A221E;
  --primary: #8BAA7A;
  --primary-dark: #6B8F5E;
  --primary-glow: rgba(139, 170, 122, 0.2);
  --accent: #A8C99A;
  --accent-glow: rgba(168, 201, 154, 0.25);
  --warm: #C4A97D;
  --warm-glow: rgba(196, 169, 125, 0.15);
  --jade: #5A8A72;
  --text: #E8E4DC;
  --text-secondary: #A8A090;
  --text-muted: #6B6558;
  --border: rgba(139, 170, 122, 0.1);
  --border-light: rgba(139, 170, 122, 0.18);
  --danger: #D45A5A;
  --warning: #C4A043;
  --radius: 16rpx;
  --radius-sm: 10rpx;
  --shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.4);

  background: var(--bg);
  color: var(--text);
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', 'STKaiti', 'KaiTi', 'Noto Serif SC', 'Helvetica Neue', sans-serif;
  min-height: 100vh;
}

/* ========== 通用卡片 ========== */
.card {
  background: var(--bg-card);
  border-radius: var(--radius);
  border: 1rpx solid var(--border);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow);
}
.card-title {
  font-size: 28rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 12rpx;
  color: var(--text);
  letter-spacing: 0.3px;
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.card-sub {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
  display: block;
}

/* ========== 按钮 ========== */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 48rpx;
  border: none;
  border-radius: var(--radius-sm);
  font-size: 30rpx;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.25s ease;
  width: 100%;
  letter-spacing: 0.5px;
}
.btn-primary {
  background: var(--primary);
  color: #FFFFFF;
}
.btn-primary:active { opacity: 0.9; transform: scale(0.98); }
.btn-secondary {
  background: var(--surface);
  color: var(--text);
  border: 1rpx solid var(--border-light);
}
.btn-sm { padding: 20rpx 36rpx; font-size: 28rpx; }

/* ========== Hero Section ========== */
.hero-section {
  text-align: center;
  padding: 10rpx 0 6rpx;
}
.hero-profile {
  width: 136rpx;
  height: 136rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--accent));
  margin: 0 auto 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  box-shadow: 0 8rpx 32rpx var(--primary-glow);
}
.hero-section h2 {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
  letter-spacing: 0.5px;
  color: var(--text);
}
.hero-section .hero-sub {
  color: var(--text-secondary);
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

/* ========== 统计数据行 ========== */
.stats-row {
  display: flex;
  gap: 16rpx;
  margin: 12rpx 0;
}
.stat-item {
  flex: 1;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 24rpx 10rpx;
  text-align: center;
}
.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
  display: block;
}
.stat-label {
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
  display: block;
}

/* ========== 快捷操作按钮 ========== */
.home-quick-action {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin: 20rpx 0;
}
.action-btn {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx 40rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius);
  cursor: pointer;
  transition: all 0.2s;
  width: 100%;
  text-align: left;
}
.action-btn:active {
  border-color: var(--primary);
  background: var(--bg-card-hover);
}
.action-btn-primary {
  background: var(--primary);
  border-color: var(--primary);
}
.action-btn-primary:active { opacity: 0.9; }
.action-icon { font-size: 48rpx; }
.action-text { font-size: 32rpx; font-weight: 600; color: var(--text); }
.action-btn-primary .action-text { color: #fff; }

/* ========== 功能入口 2x2 ========== */
.feature-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin: 12rpx 0;
}
.feature-item {
  width: calc(50% - 8rpx);
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 32rpx 24rpx;
  text-align: center;
  transition: all 0.2s;
  cursor: pointer;
  box-sizing: border-box;
}
.feature-item:active {
  border-color: var(--primary);
  background: var(--bg-card-hover);
}
.feature-item .icon { font-size: 48rpx; margin-bottom: 8rpx; display: block; }
.feature-item .label { font-size: 24rpx; color: var(--text-secondary); font-weight: 500; }

/* ========== 九种体质列表 ========== */
.constitution-card {
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 24rpx;
  margin-bottom: 12rpx;
}
.constitution-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.constitution-emoji { font-size: 96rpx; }
.constitution-name { font-size: 72rpx; font-weight: 700; color: var(--primary); }
.constitution-principle { font-size: 52rpx; color: var(--text-secondary); display: block; }

/* ========== 打卡 ========== */
.checkin-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius);
  padding: 24rpx 32rpx;
  margin-bottom: 12rpx;
}
.checkin-card.checked {
  border-color: var(--accent);
  background: rgba(168, 201, 154, 0.06);
}
.streak-text { font-size: 24rpx; color: var(--warm); }

/* ========== 节气卡片 ========== */
.solar-term-card {
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-left: 6rpx solid var(--primary);
  border-radius: var(--radius);
  padding: 28rpx;
  margin-bottom: 14rpx;
}
.solar-term-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--primary);
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.solar-tip { font-size: 24rpx; color: var(--text-secondary); line-height: 1.6; display: block; margin-bottom: 16rpx; }
.solar-foods { display: flex; gap: 12rpx; flex-wrap: wrap; }
.solar-food-tag {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  background: var(--surface);
  border-radius: 20rpx;
  color: var(--text-secondary);
  border: 1rpx solid var(--border);
}

/* ========== 诗词卡片 ========== */
.poetry-card {
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-left: 6rpx solid var(--accent);
  border-radius: var(--radius);
  padding: 28rpx;
  margin-bottom: 14rpx;
}
.solar-name { font-size: 72rpx; font-weight: 700; color: var(--accent); display: block; margin-bottom: 12rpx; }
.poem-content { margin: 16rpx 0; padding: 20rpx; background: rgba(255,255,255,0.06); border-radius: 16rpx; }
.poem-text { font-size: 28rpx; color: var(--text); line-height: 1.8; display: block; font-family: KaiTi, STKaiti, serif; }
.poem-author { font-size: 24rpx; color: var(--text-muted); margin-top: 12rpx; display: block; text-align: right; font-family: KaiTi, STKaiti, serif; }
.card-tip { font-size: 22rpx; color: var(--accent); font-style: italic; }

/* ========== 诗词弹窗 (暗色主题) ========== */
.poetry-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}
.modal-content {
  width: 100%;
  max-height: 85vh;
  background: var(--bg-card);
  border-radius: 24rpx;
  border: 1rpx solid var(--border);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 36rpx;
  border-bottom: 1rpx solid var(--border);
}
.modal-title { font-size: 36rpx; font-weight: 700; color: var(--accent); font-family: KaiTi, STKaiti, serif; }
.modal-close { font-size: 48rpx; color: var(--text-muted); line-height: 1; }
.modal-body { flex: 1; overflow-y: auto; padding: 32rpx 36rpx; }
.modal-poem { padding: 24rpx; background: var(--surface); border-radius: 16rpx; margin-bottom: 32rpx; }
.modal-poem-text { font-size: 30rpx; color: var(--text); line-height: 2; display: block; font-family: KaiTi, STKaiti, serif; }
.modal-poem-author { font-size: 26rpx; color: var(--text-muted); margin-top: 16rpx; display: block; text-align: right; font-family: KaiTi, STKaiti, serif; }
.modal-divider { height: 1rpx; background: var(--border); margin: 24rpx 0; }
.modal-story {}
.story-title { font-size: 30rpx; font-weight: 600; color: var(--accent); margin-bottom: 16rpx; display: block; }
.story-content { font-size: 28rpx; color: var(--text-secondary); line-height: 1.8; display: block; }
.modal-tip {}
.tip-title { font-size: 30rpx; font-weight: 600; color: var(--primary); margin-bottom: 12rpx; display: block; }
.tip-content { font-size: 26rpx; color: var(--text-secondary); line-height: 1.6; display: block; }
.modal-footer { padding: 24rpx 36rpx; border-top: 1rpx solid var(--border); text-align: center; }
.modal-btn {
  display: inline-block;
  padding: 16rpx 48rpx;
  background: var(--primary);
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
}

/* ========== 九种体质横向滚动 ========== */
.chip-scroll { white-space: nowrap; padding: 10rpx 0; }
.chip {
  display: inline-block;
  border: 2rpx solid var(--border);
  border-radius: 30rpx;
  padding: 10rpx 24rpx;
  margin-right: 16rpx;
  font-size: 24rpx;
  background: var(--surface);
  color: var(--text-secondary);
}

/* ========== 免责声明 ========== */
.disclaimer {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-muted);
  padding: 30rpx 20rpx;
  margin-top: 20rpx;
}
